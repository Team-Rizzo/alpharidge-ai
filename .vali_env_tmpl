# LLM Analysis (Article Intelligence V2 — deepseek-v4-flash via OpenRouter)
# Required for validating miner submissions (re-runs the analyzer for consensus scoring)
MODEL=deepseek/deepseek-v4-flash
# OpenRouter API key (sk-or-...). Get one at https://openrouter.ai/keys
API_KEY=
LLM_BASE=https://openrouter.ai/api/v1

# Validator API Configuration (API v2)
# Base URL for the miner API (API v2 endpoints: /v2/validation, /v2/validation_result, /v2/scores)
MINER_API_URL=https://alpharidge.rizzo.network/api
# HTTP timeout in seconds for API requests
BATCH_HTTP_TIMEOUT=30.0
# Interval in seconds between polling for new validations
VALIDATION_POLL_SECONDS=10
# Blocks between fetching scores from /v2/scores endpoint (default: 100 blocks, ~20 minutes)
SCORES_BLOCK_INTERVAL=100
# Timeout in seconds for the initial dispatch (validator → miner) dendrite call.
MINER_SEND_TIMEOUT=6

# Max concurrent validation threads making LLM calls.
VALIDATION_MAX_WORKERS=8
# How many tweets/messages to fetch from the API per poll cycle.
# Fetched items are split into MINER_BATCH_SIZE chunks and dispatched to different miners.
VALIDATION_FETCH_LIMIT=24
# How long (seconds) to cache LLM classification results for identical post text.
LLM_CACHE_TTL=300
# Maximum number of cached classification results held in memory.
LLM_CACHE_MAX_SIZE=1024
# --- Verifiable validator points (v2.2.0) ---
# Both have safe defaults baked into config.py, so you normally don't need to set these.
# API attestation pubkey used to verify peer reward broadcasts (public; pinned default in code).
# API_ATTESTATION_PUBKEY=5DqYRNaJ9FJ2cuJTFxbU5HDLeeotpgj6Zgkrkw4RgS6SA4nf
# Drop unsigned/unverifiable broadcasts (defaults true). Set false only to allow legacy pooling.
# ENFORCE_SIGNED_ATTESTATIONS=true
# Fraction of received attestations to deep-verify against the API (default 0.1).
# DEEP_VERIFY_SAMPLE_RATE=0.1
